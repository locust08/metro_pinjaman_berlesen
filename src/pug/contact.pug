        script.
            function contactBookingForm() {
                const today = new Date().toISOString().slice(0, 10);

                return {
                    today,
                    isLocal: ['localhost', '127.0.0.1'].includes(window.location.hostname),
                    loading: false,
                    successMessage: '',
                    errorMessage: '',
                    bookedTimes: [],
                    form: {
                        name: '',
                        email: '',
                        phone: '',
                        loanType: '',
                        date: today,
                        time: '',
                        message: ''
                    },
                    init() {
                        this.loadBookedTimes();
                    },
                    isBooked(time) {
                        return this.bookedTimes.includes(time);
                    },
                    timeLabel(time, label) {
                        return this.isBooked(time) ? `${label} - Booked` : label;
                    },
                    bookedTimeLabels() {
                        const labels = {
                            '09:00': '9:00 AM',
                            '10:00': '10:00 AM',
                            '11:00': '11:00 AM',
                            '12:00': '12:00 PM',
                            '14:00': '2:00 PM',
                            '15:00': '3:00 PM',
                            '16:00': '4:00 PM',
                            '17:00': '5:00 PM'
                        };

                        return this.bookedTimes.map((time) => labels[time] || time).join(', ');
                    },
                    async loadBookedTimes() {
                        if (!this.form.date) return;
                        try {
                            const response = await fetch(`/api/bookings/booked-slots?date=${encodeURIComponent(this.form.date)}`);
                            if (!response.ok) return;
                            const data = await response.json();
                            this.bookedTimes = data.bookedTimes || [];
                            if (this.isBooked(this.form.time)) {
                                this.form.time = '';
                            }
                        } catch (error) {
                            this.bookedTimes = [];
                        }
                    },
                    validate() {
                        if (!this.form.name.trim()) return 'Please enter your full name.';
                        if (!this.form.email.trim() && !this.form.phone.trim()) return 'Please enter either email or contact number.';
                        if (!this.form.loanType) return 'Please select a loan type.';
                        if (!this.form.date || !this.form.time) return 'Please select your preferred date and time.';
                        if (this.isBooked(this.form.time)) return 'This time slot has already been booked. Please choose another time.';
                        return '';
                    },
                    async submitBooking() {
                        this.successMessage = '';
                        this.errorMessage = this.validate();
                        if (this.errorMessage) return;

                        this.loading = true;
                        try {
                            const response = await fetch('/api/bookings', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(this.form)
                            });
                            const data = await response.json().catch(() => ({}));

                            if (!response.ok) {
                                this.errorMessage = data.message || 'This time slot is unavailable. Please choose another time.';
                                await this.loadBookedTimes();
                                return;
                            }

                            this.successMessage = 'Thank you. Your preferred slot has been submitted and blocked for testing.';
                            this.errorMessage = '';
                            this.form.time = '';
                            await this.loadBookedTimes();
                        } catch (error) {
                            this.errorMessage = 'Booking service is not running. Please use the booking test server.';
                        } finally {
                            this.loading = false;
                        }
                    },
                    async resetTestBookings() {
                        this.successMessage = '';
                        this.errorMessage = '';
                        try {
                            const response = await fetch('/api/test/reset-bookings', { method: 'POST' });
                            if (!response.ok) throw new Error('Reset failed');
                            this.successMessage = 'Test bookings have been reset.';
                            await this.loadBookedTimes();
                        } catch (error) {
                            this.errorMessage = 'Could not reset test bookings.';
                        }
                    }
                };
            }
        script(type="text/javascript", src="js/global-88881.js?v=1782722021")
